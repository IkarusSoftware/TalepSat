# Database
# Production icin PostgreSQL onerilir (Vercel Postgres, Neon, Supabase, Render, vb.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# App URLs
NEXTAUTH_URL="https://app.example.com"
# Uploads ve eski /uploads/* kayitlari icin public origin
MEDIA_PUBLIC_BASE_URL="https://app.example.com"

# Auth / cron
AUTH_SECRET="generate-a-random-secret-here"
CRON_SECRET="set-a-random-secret-for-cron-routes"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Expo push (mobile push icin gerekli)
EXPO_ACCESS_TOKEN=

# Iyzico billing
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL="https://api.iyzipay.com"
IYZICO_CALLBACK_URL="https://app.example.com/api/billing/webhook"
# Optional, sadece webhook signature dogrulamasinda kullanilir
IYZICO_MERCHANT_ID=

# SMTP bu dosyadan degil, admin panelindeki Ayarlar > SMTP ve E-posta bolumunden yonetilir.
